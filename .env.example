# Copy this file to .env and fill in your values.
# Most variables (AIO_runtime_* and AIO_ims_contexts_*) are generated automatically
# by running: aio app use
# After running that command, manually add AIO_STATIC_HOST (see below).

# ------------------------------------------------------------------
# App-specific (set manually after first deploy or aio app use)
# ------------------------------------------------------------------

# The static hosting hostname for your App Builder workspace.
# Format: {namespace}.adobeio-static.net
# Your namespace is the value of AIO_runtime_namespace below.
# Example: 27200-myproject-stage.adobeio-static.net
AIO_STATIC_HOST=YOUR_NAMESPACE.adobeio-static.net

# ------------------------------------------------------------------
# Adobe I/O Runtime (generated by: aio app use)
# ------------------------------------------------------------------

# Runtime auth token in the format {uuid}:{secret}
AIO_runtime_auth=YOUR_RUNTIME_UUID:YOUR_RUNTIME_SECRET

# Namespace in the format {org_id}-{project_name}-{workspace_name}
AIO_runtime_namespace=YOUR_NAMESPACE

AIO_runtime_apihost=https://adobeioruntime.net

# ------------------------------------------------------------------
# IMS OAuth Server-to-Server credentials (generated by: aio app use)
# The variable names below contain your credential name, which is set
# in Adobe Developer Console. Run `aio app use` and these will be
# written automatically with the correct names for your project.
# ------------------------------------------------------------------

AIO_ims_contexts_YOUR_CREDENTIAL_NAME_client__id=YOUR_CLIENT_ID
AIO_ims_contexts_YOUR_CREDENTIAL_NAME_client__secrets=["YOUR_CLIENT_SECRET"]
AIO_ims_contexts_YOUR_CREDENTIAL_NAME_technical__account__email=YOUR_TECH_ACCOUNT_UUID@techacct.adobe.com
AIO_ims_contexts_YOUR_CREDENTIAL_NAME_technical__account__id=YOUR_TECH_ACCOUNT_ID@techacct.adobe.com
AIO_ims_contexts_YOUR_CREDENTIAL_NAME_scopes=["openid","AdobeID","read_organizations","additional_info.projectedProductContext","session","additional_info.roles","profile"]
AIO_ims_contexts_YOUR_CREDENTIAL_NAME_ims__org__id=YOUR_IMS_ORG_ID@AdobeOrg

# ------------------------------------------------------------------
# Service API Key (same value as your client_id above)
# ------------------------------------------------------------------

SERVICE_API_KEY=YOUR_CLIENT_ID
